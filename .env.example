# NEXUS Website — Environment Variables
# Copy to .env.local and fill in your Supabase project values.
# NEVER commit .env.local or expose the service role key.

# Supabase (client-safe anon key only)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# NEXUS Cloud API (required for portal services)
VITE_NEXUS_CLOUD_URL=http://localhost:8787

# Optional — override for local GitHub Pages preview (repo: NEXUSEOS/NEXUS-website)
# VITE_BASE_PATH=/NEXUS-website/
# VITE_SITE_URL=https://nexuseos.github.io/NEXUS-website
# GITHUB_REPOSITORY=NEXUSEOS/NEXUS-website
