{
  "name": "nexus-website",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-sitemap.mjs && node scripts/generate-rss.mjs && tsc -b && vite build",
    "build:pages": "node scripts/build-pages.mjs",
    "build:pages:shims": "VITE_FORCE_SHIMS=true node scripts/build-pages.mjs",
    "lint": "eslint .",
    "lighthouse": "node scripts/lighthouse-check.mjs",
    "preview": "vite preview",
    "preview:pages": "vite preview --base /NEXUS-website/",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install chromium"
  },
  "dependencies": {
    "@mdx-js/rollup": "^3.1.1",
    "@nexus/aether": "file:../nexus-platform/packages/aether",
    "@nexus/analytics": "file:../nexus-platform/packages/analytics",
    "@nexus/auth": "file:../nexus-platform/packages/auth",
    "@nexus/config": "file:../nexus-platform/packages/config",
    "@nexus/downloads": "file:../nexus-platform/packages/downloads",
    "@nexus/integration": "file:../nexus-platform/packages/integration",
    "@nexus/sdk-cms": "file:../nexus-sdk/packages/cms",
    "@nexus/cms-renderer": "file:../nexus-platform/packages/cms-renderer",
    "@nexus/sdk-platform": "file:../nexus-sdk/packages/platform",
    "@nexus/platform": "file:../nexus-platform/packages/platform",
    "@nexus/design-system": "file:../nexus-design-system",
    "@nexus/navigation": "file:../nexus-platform/packages/navigation",
    "@nexus/theme": "file:../nexus-platform/packages/theme",
    "@nexus/ui": "file:../nexus-platform/packages/ui",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@supabase/supabase-js": "^2.110.2",
    "@types/mdx": "^2.0.14",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "@playwright/test": "^1.52.0",
    "vite": "^8.1.1"
  }
}
